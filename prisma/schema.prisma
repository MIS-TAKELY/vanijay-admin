datasource db {
  provider = "postgresql"
  extensions = [vector]
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  
  // Added for Better-Auth & UnifiedAuth support
  username      String?   @unique
  displayUsername String?
  firstName     String?
  lastName      String?
  phone         String?   @unique
  phoneVerified Boolean?  @default(false)
  otp           String?
  otpExpiresAt  DateTime?
  avatarImageUrl String?
  image         String?
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  logs      SystemLog[]
  sessions  Session[]
  accounts  Account[]
}

model SystemLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  adminId   String
  createdAt DateTime @default(now())
  
  admin     User    @relation(fields: [adminId], references: [id])
}

model Session {
    id        String   @id @default(cuid())
    expiresAt DateTime
    token     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([token])
    @@map("session")
}

model Account {
    id                    String    @id @default(cuid())
    accountId             String
    providerId            String
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime @default(now())
    updatedAt             DateTime @updatedAt

    @@unique([providerId, accountId])
    @@map("account")
}

model Verification {
    id         String    @id @default(cuid())
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime? @default(now())
    updatedAt  DateTime? @updatedAt

    @@map("verification")
}

// Landing Page Content Management Models

// Landing Page Category Cards (shown at top of homepage)
model LandingPageCategoryCard {
  id        String   @id @default(cuid())
  categoryId String  // ID of the category from the main database
  image     String?  // Image URL (optional, replaces icon)
  // count removed, will be calculated dynamically
  color     String   // Gradient classes, e.g., "from-blue-500 to-purple-600"
  darkColor String?  // Dark mode gradient
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_page_category_cards")
}

// Category Swiper Sections (horizontal scrolling product sections)
model LandingPageCategorySwiper {
  id        String   @id @default(cuid())
  title     String   // e.g., "Best Deals on Electronics"
  category  String   // Category name to filter products
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("landing_page_category_swipers")
}

// Product Grid Sections (grid layout product sections)
model LandingPageProductGrid {
  id           String   @id @default(cuid())
  title        String   // e.g., "Featured Products"
  topDealAbout String   // Category/tag to filter products
  productIds   String[] // Optional: specific product IDs to show
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("landing_page_product_grids")
}
